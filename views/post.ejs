<% const body = `<article class="card"><h2>${post.matched_area||'Post'}</h2><p>${post.rent_text||''} · ${post.brokerage_label} · ${post.post_type}</p><pre>${post.message||''}</pre><div class="images">${images.map(i=>`<img src="/images/${post.id.replace(/[^a-zA-Z0-9_-]/g,'_')}/${i.position}.jpg">`).join('')}</div><p><a href="${post.source_post_url}">Source post</a></p></article>` %><%- include('layout',{body}) %>

<% const body = `<section class="card"><h2>Settings</h2>${saved?`<p class="ok">${saved}</p>`:''}<form method="post" class="settings"><label>Facebook group URL<input name="group_url" value="${settings.group_url||''}"></label><label>Keywords<textarea name="keywords">${settings.keywords||''}</textarea></label><label>Exclude keywords<textarea name="exclude_keywords">${settings.exclude_keywords||''}</textarea></label><label>Areas<textarea name="areas">${settings.areas||''}</textarea></label><label>Max rent (0 disables)<input name="max_rent" value="${settings.max_rent||'0'}"></label><label><input type="checkbox" name="polling_enabled" value="true" ${settings.polling_enabled==='true'?'checked':''}> Enable scheduler</label><label><input type="checkbox" name="telegram_enabled" value="true" ${settings.telegram_enabled==='true'?'checked':''}> Telegram alerts</label><button>Save and recompute filters</button></form></section>` %><%- include('layout',{body}) %>

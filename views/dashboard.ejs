<% let body = ''; %><% body += `<section class="card"><form class="filters"><input name="q" placeholder="Search local DB" value="${query.q||''}"><label><input type="checkbox" name="match" value="1" ${query.match==='1'?'checked':''}> Matches only</label><select name="sort"><option value="created_time">Newest</option><option value="rent_amount">Rent</option><option value="matched_area">Area</option></select><button>Search</button></form><form method="post" action="/manual-ingest"><button ${remaining<=0?'disabled':''}>Fetch now</button></form></section>`; %>
<% posts.forEach(p=>{ body += `<article class="post ${p.is_match?'match':''}"><h3>${p.matched_area||'Unknown area'} · ${p.rent_text||'Rent n/a'} · ${p.brokerage_label}</h3><p><b>${p.post_type}</b> ${p.is_hall_sharing?' · Hall sharing':''} ${p.is_match?' · ✅ match':' · '+(p.excluded_reason||'not matched')}</p><p>${(p.message||'').slice(0,500)}</p><div class="thumbs">${(imgs[p.id]||[]).map(i=>`<img src="/images/${p.id.replace(/[^a-zA-Z0-9_-]/g,'_')}/${i.position}.jpg">`).join('')}</div><a href="/post/${encodeURIComponent(p.id)}">Details</a></article>` }) %>
<%- include('layout',{body}) %>
